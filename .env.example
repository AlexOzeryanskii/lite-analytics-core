# Development
DEBUG=true

# Database
DATABASE_URL=sqlite:///./analytics.db

# Private API access (required when DEBUG=false)
API_KEY=change-me-to-a-long-random-secret

# CORS — comma-separated origins (no wildcard in production)
ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# Dashboard Basic Auth (required when DEBUG=false)
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=change-me-to-a-strong-password

# Web Push (VAPID) — generate keys for production
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CLAIMS_SUB=mailto:admin@yourdomain.com

# Push delivery
PUSH_MAX_FAIL_COUNT=5
